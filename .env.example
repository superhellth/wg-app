# ── .env (repo root — read automatically by docker compose) ─────────
# Postgres password (the `wg` user/db are created by the db container).
POSTGRES_PASSWORD=change-me-strong

# Web build args (baked into the PWA at build time; VITE_ = public).
VITE_API_URL=https://wg.yourdomain.com
VITE_VAPID_PUBLIC_KEY=

# Cloudflare Tunnel token (token-managed tunnel → point hostname at http://caddy:80).
TUNNEL_TOKEN=

# ── api/.env (server secrets — passed to api + worker containers) ────
# DATABASE_URL is injected by compose (points at the `db` service); no need to set
# it here for the Docker deploy. For bare local dev, use:
#   DATABASE_URL=postgres://wg:wg@localhost:5432/wg
PORT=3000
HOST=0.0.0.0

# WG join secret — the single shared secret proving "in this WG".
# This exact value is the bearer token every device holds (Authorization header).
WG_TOKEN_SECRET=change-me-long-random

# Web Push (VAPID) — generate once: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
